{
    "formatVersion": "1.0",
    "package": {
        "id": "com.jwcontrol.jwplc-basic",
        "name": "JWPLC Basic OpenPLC",
        "version": "2.1.0-alpha.12",
        "vendor": {
            "name": "JW Control",
            "url": "https://www.jw-control.com",
            "logo": "assets/jwplcbasic.png"
        },
        "description": "Integración del JWPLC Basic 2.0.0 con OpenPLC Editor 4.2.6/4.2.7 usando el formato Vendor Plugin Package (.vpp).",
        "license": "GPL-3.0-or-later",
        "minEditorVersion": "4.2.6"
    },
    "devices": [
        {
            "id": "jwplc-basic-2-0-0",
            "name": "JWPLC BASIC [2.0.0]",
            "category": "Arduino",
            "preview": "assets/jwplcbasic.png",
            "screens": {
                "Modbus": "screens/modbus.json",
                "JWPLC Backplane": "screens/backplane.json"
            },
            "target": {
                "type": "arduino-cli",
                "core": "jwplc:esp32",
                "platform": "jwplc:esp32:jwplcbasic",
                "boardManagerUrl": "https://raw.githubusercontent.com/JW-Control/platform-jwplc/main/JWPLC/package_jwplc_index.json"
            },
            "hal": {
                "type": "arduino",
                "source": "hal/jwplcbasic.cpp",
                "define": [
                    "JWPLC_BASIC",
                    "OPENPLC_JWPLC_BASIC",
                    "MBTCP_ETHERNET"
                ],
                "extraArduinoLibraries": []
            },
            "defaults": {
                "pins": {
                    "defaultDin": [
                        "I0_0",
                        "I0_1",
                        "I0_2",
                        "I0_3",
                        "I0_4",
                        "I0_5",
                        "I0_6",
                        "I0_7"
                    ],
                    "defaultDout": [
                        "Q0_0",
                        "Q0_1",
                        "Q0_2",
                        "Q0_3",
                        "Q0_4",
                        "Q0_5",
                        "Q0_6",
                        "Q0_7"
                    ],
                    "defaultAin": [],
                    "defaultAout": []
                }
            },
            "specs": {
                "CPU": "ESP32-WROOM-32E / 240 MHz",
                "RAM": "520 KB",
                "Flash": "4 MB",
                "Digital Pins": "8 DI + 8 DO",
                "Analog Pins": "No habilitado",
                "PWM Pins": "No habilitado",
                "WiFi": "Yes",
                "Bluetooth": "Yes",
                "Ethernet": "Yes - W5500",
                "RS-485": "Yes",
                "RTC": "Yes - DS3232",
                "FRAM": "Yes",
                "microSD": "Yes",
                "Display": "TFT ST7789",
                "Keyboard": "7 buttons"
            },
            "capabilities": {
                "pinMapping": true,
                "vppIo": true,
                "modbusTcpRemote": false,
                "ethercat": false,
                "modbusTcpServer": true,
                "opcuaServer": false,
                "s7Server": false,
                "debuggerTransports": [
                    "modbus-serial",
                    "modbus-tcp"
                ],
                "pythonFunctionBlocks": false,
                "arduinoApiCompletions": true,
                "hasRuntimeStats": false,
                "isInProcessSimulator": false,
                "directUsbUpload": true
            },
            "debug": {
                "channels": [
                    {
                        "label": "Modbus RTU",
                        "channel": "rtu",
                        "enabledWhen": {
                            "$ref": "screens.modbus_rtu.enabled"
                        },
                        "params": {
                            "port": {
                                "$ref": "screens.modbus_rtu.rtu_debug_port",
                                "fallback": "configuration.communicationPort",
                                "required": "Selecciona un puerto de depuración Modbus RTU. Para RS-485 usa el COM del adaptador USB-RS485."
                            },
                            "baudRate": {
                                "$ref": "screens.modbus_rtu.rtu_baud_rate",
                                "default": "115200",
                                "as": "number"
                            },
                            "slaveId": {
                                "$ref": "screens.modbus_rtu.rtu_slave_id",
                                "default": 1,
                                "as": "number"
                            }
                        }
                    },
                    {
                        "label": "Modbus TCP / W5500",
                        "channel": "tcp",
                        "enabledWhen": {
                            "$ref": "screens.modbus_tcp.enabled"
                        },
                        "params": {
                            "ipAddress": {
                                "$ref": "screens.modbus_tcp.tcp_debug_ip_address",
                                "fallback": "screens.modbus_tcp.ip_address",
                                "required": "Configura la IP del JWPLC Basic para depuración por Modbus TCP. Si usas DHCP, usa JWPLC Device Discovery o coloca la IP asignada en Debug IP Address."
                            }
                        }
                    }
                ]
            },
            "moduleSystem": {
                "enabled": true,
                "maxSlots": 8,
                "modules": [
                    {
                        "id": "jwplc-basic-controller",
                        "name": "JWPLC Basic v2.0.0",
                        "fixed": true,
                        "image": "assets/jwplcbasic.png",
                        "description": "Controlador principal JWPLC Basic v2.0.0 con I/O local, Ethernet W5500, RS-485, RTC, FRAM, microSD, display y botonera.",
                        "specs": {
                            "CPU": "ESP32-WROOM-32E / 240 MHz",
                            "IO": "8 DI / 8 DO locales",
                            "Ethernet": "W5500",
                            "RS485": "Serial2",
                            "Role": "Main controller"
                        },
                        "io": {
                            "digitalInputs": 8,
                            "digitalOutputs": 8,
                            "analogInputs": 0,
                            "analogOutputs": 0
                        },
                        "addressMapping": {
                            "channels": [
                                {
                                    "name": "I0_0",
                                    "type": "digitalInput",
                                    "dataType": "BOOL",
                                    "addressPrefix": "%IX"
                                },
                                {
                                    "name": "I0_1",
                                    "type": "digitalInput",
