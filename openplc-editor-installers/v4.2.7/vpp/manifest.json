                                    "dataType": "BOOL",
                                    "addressPrefix": "%IX"
                                },
                                {
                                    "name": "I0_6",
                                    "type": "digitalInput",
                                    "dataType": "BOOL",
                                    "addressPrefix": "%IX"
                                },
                                {
                                    "name": "I0_7",
                                    "type": "digitalInput",
                                    "dataType": "BOOL",
                                    "addressPrefix": "%IX"
                                },
                                {
                                    "name": "Q0_0",
